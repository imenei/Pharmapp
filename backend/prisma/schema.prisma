// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  admin
  pharmacist
  supplier
}

enum UserStatus {
  pending
  approved
  rejected
}

enum PaymentStatus {
  pending
  approved
  rejected
}

enum SubscriptionTier {
  bronze
  silver
  gold
}

enum NotificationType {
  info
  warning
  success
  error
  payment
  subscription
  listing
  offer
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String     @map("password_hash")
  role         UserRole
  status       UserStatus @default(pending)
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  profile              Profile?
  notifications        Notification[]
  sentContactMessages  ContactMessage[]
  refreshTokens        RefreshToken[]

  @@map("users")
}

model Profile {
  id            String  @id
  companyName   String? @map("company_name")
  address       String?
  wilaya        String?
  phone         String?
  description   String? @db.Text
  avatarUrl     String? @map("avatar_url")
  registerUrl   String? @map("register_url")  // ← registre de commerce

  user                 User                 @relation(fields: [id], references: [id], onDelete: Cascade)
  supplierData         SupplierData?
  pharmacistData       PharmacistData?
  listings             Listing[]
  offers               Offer[]
  ratingsGiven         Rating[]             @relation("RatingsGiven")
  ratingsReceived      Rating[]             @relation("RatingsReceived")
  subscriptionPayments SubscriptionPayment[]

  @@map("profiles")
}

model SupplierData {
  id             String @id @default(uuid())
  profileId      String @unique @map("profile_id")
  totalViews     Int    @default(0) @map("total_views")
  totalDownloads Int    @default(0) @map("total_downloads")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("supplier_data")
}

model PharmacistData {
  id            String  @id @default(uuid())
  profileId     String  @unique @map("profile_id")
  licenseNumber String? @map("license_number")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("pharmacist_data")
}

model Wilaya {
  code Int    @id
  nom  String

  @@map("wilayas")
}

// ─── Subscriptions ────────────────────────────────────────────────────────────

model SubscriptionPlan {
  id           String           @id @default(uuid())
  name         String
  tier         SubscriptionTier
  price        Int
  yearlyPrice  Int              @map("yearly_price")
  durationDays Int              @map("duration_days")
  features     String[]
  isActive     Boolean          @default(true) @map("is_active")
  createdAt    DateTime         @default(now()) @map("created_at")

  payments SubscriptionPayment[]

  @@map("subscription_plans")
}

model SubscriptionPayment {
  id                 String        @id @default(uuid())
  userId             String        @map("user_id")
  subscriptionPlanId String        @map("subscription_plan_id")
  proofUrl           String        @map("proof_url")
  status             PaymentStatus @default(pending)
  subscriptionStart  DateTime?     @map("subscription_start")
  subscriptionEnd    DateTime?     @map("subscription_end")
  isActive           Boolean       @default(false) @map("is_active")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  profile          Profile          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionPlan SubscriptionPlan @relation(fields: [subscriptionPlanId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("subscription_payments")
}

// ─── Listings ────────────────────────────────────────────────────────────────

model Listing {
  id            String   @id @default(uuid())
  supplierId    String   @map("supplier_id")
  title         String
  description   String?  @db.Text
  fileUrl       String   @map("file_url")
  extractedText String?  @db.Text @map("extracted_text")
  views         Int      @default(0)
  downloads     Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  supplier Profile @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  products ListingProduct[]

  @@index([supplierId])
  @@index([createdAt])
  @@map("listings")
}

model ListingProduct {
  id          String   @id @default(uuid())
  listingId   String   @map("listing_id")
  productName String   @map("product_name")
  quantity    Int?
  price       Decimal? @db.Decimal(10, 2)
  createdAt   DateTime @default(now()) @map("created_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([productName])
  @@map("listing_products")
}

// ─── Offers ──────────────────────────────────────────────────────────────────

model Offer {
  id          String   @id @default(uuid())
  supplierId  String   @map("supplier_id")
  title       String
  description String   @db.Text
  imageUrl    String?  @map("image_url")
  fileUrl     String?  @map("file_url")
  views       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  expiresAt   DateTime @map("expires_at")

  supplier Profile @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
  @@index([expiresAt])
  @@map("offers")
}

// ─── Ratings ─────────────────────────────────────────────────────────────────

model Rating {
  id           String   @id @default(uuid())
  pharmacistId String   @map("pharmacist_id")
  supplierId   String   @map("supplier_id")
  score        Int
  comment      String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  pharmacist Profile @relation("RatingsGiven",    fields: [pharmacistId], references: [id], onDelete: Cascade)
  supplier   Profile @relation("RatingsReceived", fields: [supplierId],   references: [id], onDelete: Cascade)

  @@unique([pharmacistId, supplierId])
  @@index([supplierId])
  @@map("ratings")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  title     String
  message   String           @db.Text
  type      NotificationType @default(info)
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ─── Contact Messages ─────────────────────────────────────────────────────────

model ContactMessage {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  name      String
  email     String
  subject   String
  message   String   @db.Text
  status    String   @default("new")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("contact_messages")
}

// ─── Refresh Tokens ───────────────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}
