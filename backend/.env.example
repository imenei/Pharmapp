NODE_ENV=production
PORT=4000
DATABASE_URL=postgresql://pharmaflow:change_me@127.0.0.1:5432/pharmaflow?schema=public
FRONTEND_URL=https://app.example.com
CORS_ORIGINS=https://app.example.com,https://www.app.example.com
UPLOAD_DIR=/var/www/pharmapp/shared/uploads
JWT_SECRET=replace_with_a_64_plus_character_random_secret
JWT_REFRESH_SECRET=replace_with_a_different_64_plus_character_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
GMAIL_USER=
GMAIL_PASS=
